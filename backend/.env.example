# =============================================================================
# DSA AI COACH — BACKEND ENVIRONMENT VARIABLES
# =============================================================================
# Fill in values marked [REQUIRED] before starting the backend.
# [LOCAL DEFAULT] values work automatically with: docker compose up -d
# [OPTIONAL] values can be left empty for local dev.
# =============================================================================


# =============================================================================
# [REQUIRED] ANTHROPIC API KEY
# Powers all AI coaching — hints, pattern explanations, contextual feedback.
# The app crashes on the first AI call without a valid key.
#
# Setup:
#   1. Go to https://console.anthropic.com
#   2. Sign up / log in
#   3. Left sidebar → "API Keys" → "Create Key"
#   4. Copy the sk-ant-... value below
#
# Free tier: $5 credit on signup (~500k tokens, weeks of dev usage)
# Cost per hint/explanation: ~$0.003 at Claude 3.5 Sonnet rates
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# =============================================================================
# [REQUIRED] JWT SECRET
# Signs and verifies all user login tokens. A weak/placeholder value means
# anyone can forge tokens and log in as any user.
#
# Generate a strong secret (pick one):
#   Node:   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   Bash:   openssl rand -hex 64
#   Online: https://generate-secret.vercel.app/64
#
# Paste the output (a 128-char hex string) below.
# =============================================================================
JWT_SECRET=replace-this-with-a-long-random-secret


# =============================================================================
# [REQUIRED FOR CODE EXECUTION] JUDGE0 API KEY
# Runs user-submitted code in a sandbox against test cases.
# Without this the "Submit Code" button silently returns empty results.
#
# Option A — RapidAPI hosted (easiest, free: 50 req/day):
#   1. Go to https://rapidapi.com/judge0-official/api/judge0-ce
#   2. Sign up for a free RapidAPI account
#   3. Click "Subscribe to Test" → choose Basic (free)
#   4. Copy your "X-RapidAPI-Key" from the Header Parameters panel
#   5. Paste it as JUDGE0_API_KEY below
#   6. Keep JUDGE0_BASE_URL as the RapidAPI URL
#
# Option B — Self-hosted Docker (unlimited, no key needed):
#   1. Add judge0 service to docker-compose.yml
#   2. Set JUDGE0_BASE_URL=http://localhost:2358
#   3. Leave JUDGE0_API_KEY empty
#
# Option A is faster to set up for local dev.
# =============================================================================
JUDGE0_API_KEY=your_judge0_rapidapi_key_here
JUDGE0_BASE_URL=https://judge0-ce.p.rapidapi.com


# =============================================================================
# [LOCAL DEFAULT] MONGODB
# Primary database — users, problems, sessions, progress.
# Works automatically when you run: docker compose up -d
#
# For MongoDB Atlas (cloud / production):
#   1. Go to https://cloud.mongodb.com → Create free M0 cluster
#   2. Database Access → Add user (readWrite role)
#   3. Network Access → Allow 0.0.0.0/0
#   4. Connect → copy the connection string
#   5. Replace <username>:<password> in the string
#   Format: mongodb+srv://user:pass@cluster.mongodb.net/dsa-coach
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/dsa-coach


# =============================================================================
# [LOCAL DEFAULT] WEAVIATE — Vector database for RAG pattern knowledge
# Works automatically when you run: docker compose up -d
# No API key needed for local Docker instance.
#
# For Weaviate Cloud (production):
#   1. Go to https://console.weaviate.cloud
#   2. Create a free Sandbox cluster (14-day trial, no credit card)
#   3. Copy the Cluster URL → paste as WEAVIATE_URL
#   4. Copy the API Key → paste as WEAVIATE_API_KEY
#   Format: https://your-cluster-id.weaviate.network
# =============================================================================
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=


# =============================================================================
# SERVER
# =============================================================================
PORT=3001
NODE_ENV=development

# Used for strict CORS in production. In development any localhost:PORT is
# allowed automatically — you don't need to change this for local dev.
FRONTEND_URL=http://localhost:3000

LOG_LEVEL=info


# =============================================================================
# [OPTIONAL — Phase 1] STRIPE — Payments for Pro plan
# Leave empty for now. Add when building /pricing page and upgrade flow.
#
# Setup (when ready):
#   1. Go to https://dashboard.stripe.com/register (no business needed)
#   2. Developers → API Keys → copy "Secret key" (sk_test_...)
#   3. For webhooks: Developers → Webhooks → Add endpoint
#      URL: https://your-backend.railway.app/api/payments/webhook
#      Events to select: checkout.session.completed,
#                        customer.subscription.deleted,
#                        invoice.payment_failed
#   4. Copy the "Signing secret" (whsec_...) → paste as STRIPE_WEBHOOK_SECRET
#   Note: sk_test_... keys are safe — no real charges until you use sk_live_...
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# =============================================================================
# [OPTIONAL — Phase 1] GOOGLE SHEETS — RAG knowledge base source
# Leave empty for now. Required when you run: npm run seed:patterns
#
# Setup (when ready):
#   1. Go to https://console.cloud.google.com → create a project
#   2. APIs & Services → Library → enable "Google Sheets API"
#   3. APIs & Services → Credentials → Create API Key → copy it below
#   4. Create your pattern knowledge Google Sheet with columns:
#      patternId | title | videoUrl | description | difficulty
#   5. Share the sheet: click Share → Anyone with the link → Viewer
#   6. Copy the Sheet ID from the URL:
#      https://docs.google.com/spreadsheets/d/[SHEET_ID_HERE]/edit
# =============================================================================
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEETS_ID=
